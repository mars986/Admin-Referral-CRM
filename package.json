{
  "name": "apex-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:cf": "opennextjs-cloudflare build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "resend:create-templates": "tsx scripts/create-resend-templates.ts",
    "resend:test-emails": "tsx scripts/test-resend-emails.ts",
    "stripe:import:dry": "node scripts/import-stripe-products.mjs --dry-run",
    "stripe:import:test": "node scripts/import-stripe-products.mjs",
    "stripe:import:live": "node scripts/import-stripe-products.mjs --live-confirm",
    "preview": "npm run build:cf && wrangler dev",
    "deploy": "npm run build:cf && opennextjs-cloudflare deploy",
    "cf:types": "wrangler types",
    "cf:check": "wrangler check",
    "db:migrate:local": "wrangler d1 migrations apply apex-compounding-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply apex-compounding-db --remote",
    "db:seed:local": "wrangler d1 execute apex-compounding-db --local --file ./seed/0001_seed.sql",
    "db:seed:remote": "wrangler d1 execute apex-compounding-db --remote --file ./seed/0001_seed.sql",
    "db:seed:referrals:local": "wrangler d1 execute apex-compounding-db --local --file ./seed/0002_referral_seed.sql",
    "db:seed:referrals:remote": "wrangler d1 execute apex-compounding-db --remote --file ./seed/0002_referral_seed.sql"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.3.0",
    "hono": "^4.12.22",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.1",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "wrangler": "^4.94.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
